PORT=5050

# Deepgram
DEEPGRAM_API_KEY=YOUR_DEEPGRAM_API_KEY
DEEPGRAM_MODEL=nova-3
DEEPGRAM_SMART_FORMAT=true
DEEPGRAM_FILLER_WORDS=true
DEEPGRAM_UTTERANCES=true
DEEPGRAM_PUNCTUATE=true

# Google Gemini (primary LLM)
GOOGLE_AI_API_KEY=YOUR_GOOGLE_AI_STUDIO_KEY
GOOGLE_AI_MODEL=gemini-2.5-flash

# Groq (fallback LLM — used automatically if Gemini fails)
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=YOUR_GROQ_API_KEY
GROQ_MODEL=llama-3.1-8b-instant

# OpenRouter (supports DeepSeek and many other models)
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY
OPENROUTER_MODEL=openai/gpt-oss-120b:free
OPENROUTER_SITE_URL=http://localhost:8081
OPENROUTER_APP_NAME=Rhetora

# LLM provider selection: auto, gemini, groq, openrouter
LLM_PROVIDER=auto
# Used only when LLM_PROVIDER=auto
LLM_FALLBACK_ORDER=gemini,groq,openrouter
